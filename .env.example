# PharmaOS AI - Environment Variables
# Copy this to .env and fill in production values

# ─── Application ────────────────────────────────────────────────────────────
APP_NAME=PharmaOS AI
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:3000"]

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pharmaos
DB_ECHO=false

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── JWT Authentication ────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET_KEY=CHANGE-ME-IN-PRODUCTION
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── WhatsApp Cloud API ────────────────────────────────────────────────────
# HUMAN ACTION REQUIRED: Set up a Meta Business Account and WhatsApp Business API
# https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# ─── Twilio Voice (Future) ─────────────────────────────────────────────────
# HUMAN ACTION REQUIRED: Create Twilio account and provision phone number
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── AI / LLM ──────────────────────────────────────────────────────────────
# HUMAN ACTION REQUIRED: Obtain API key from OpenAI or Anthropic
LLM_API_KEY=
LLM_MODEL=gpt-4o

# ─── File Storage ───────────────────────────────────────────────────────────
S3_BUCKET=pharmaos-uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
